# ============================================================
# AgAI_26: Founder Decision Engine — .gitignore
# ============================================================

# ------------------------------------------------------------
# Environment files — NEVER commit these
# ------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.production.local
backend/.env
frontend/.env.local

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/
backend/venv/
.pytest_cache/
.coverage
htmlcov/
*.log

# ------------------------------------------------------------
# Test files — not for production
# ------------------------------------------------------------
backend/test_*.py
test_*.py

# ------------------------------------------------------------
# Node / Next.js
# ------------------------------------------------------------
node_modules/
frontend/node_modules/
.next/
frontend/.next/
out/
frontend/out/
build/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------------------------
# Frontend git (Next.js creates its own .git — remove it)
# ------------------------------------------------------------
frontend/.git/

# ------------------------------------------------------------
# IDE and editor
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# Supabase local
# ------------------------------------------------------------
.supabase/

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
*.dockerignore

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
